# --- App Settings ---
APP_ENV=enterprise  # development, production, enterprise
APP_NAME="SEO Enterprise Platform"
DEBUG=False

# --- Security & Auth ---
# IMPORTANT: Change this to a random long string in production!
SECRET_KEY=generate-a-strong-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALLOWED_ORIGINS="http://localhost:3000,https://your-enterprise-domain.com"

# --- Infrastructure ---
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=sqlite:///./database.db

# --- Deployment / Automation (Global Defaults) ---
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BRANCH=main

# --- LLM Providers ---
LLM_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_HOST=http://localhost:11434

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
